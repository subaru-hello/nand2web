{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nand2web",
  "compatibility_date": "2026-07-01",
  // Static-assets-only Worker: the whole MVP is client-side. A `main` script
  // (Hono API + Durable Object sync) is a planned phase-3 addition.
  "assets": {
    "directory": "./apps/web/dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [{ "pattern": "cs.n10u.jp", "custom_domain": true }]
}
